# Valeurs par defaut (commitees). Les secrets vont dans .env.local (NON commite).
APP_ENV=dev
APP_SECRET=change_me_in_env_local

# BDD : adapte user/pass/host/dbname a ton environnement dans .env.local
DATABASE_URL="mysql://root:root@127.0.0.1:3306/icon_dahomey?serverVersion=8.0.32&charset=utf8mb4"

# Mailer : par defaut Mailpit/MailCatcher en local (http://localhost:8025)
MAILER_DSN=smtp://localhost:1025
MAILER_FROM="Icon Dahomey <no-reply@icon-dahomey.local>"

# Messenger : transport Doctrine (aucune install RabbitMQ requise)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# API SMS externe (HttpClient) - a renseigner dans .env.local
SMS_API_URL=
SMS_API_TOKEN=

