{% extends 'base.html.twig' %}
{% block title %}{{ product.name }} — Icon Dahomey{% endblock %}

{% block main %}
<div class="container pd">
    <div class="pd-gallery">
        <div class="main-img">
            <span class="monogram">Icon</span>
            {% if product.mainImage %}
                <img src="{{ asset('uploads/' ~ product.mainImage.filename) }}" alt="{{ product.name }}" onerror="this.style.display='none'" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">
            {% endif %}
        </div>
        <div class="thumbs">
            {% for image in product.images %}
                <div style="background-image:url('{{ asset('uploads/' ~ image.filename) }}');background-size:cover;background-position:center"></div>
            {% else %}<div></div><div></div><div></div>{% endfor %}
        </div>
    </div>

    <div class="pd-info">
        <div class="breadcrumb">Accueil / Boutique / {{ product.category ? product.category.name : 'Creation' }}</div>
        <h1>{{ product.name }}</h1>
        <div class="pd-price">{{ product.basePrice }} &euro;</div>
        <p class="muted">{{ product.description|slice(0, 160) }}{% if product.description|length > 160 %}...{% endif %}</p>

        {{ form_start(form) }}
            <div class="block-label">Type de produit</div>
            <div class="toggle-group">
                {% for child in form.selectedType %}
                    <label>{{ form_widget(child) }}<span>{{ child.vars.label }}</span></label>
                {% endfor %}
            </div>

            {% if form.m_poitrine is defined %}
                <div id="measure-block">
                    <div class="block-label">Mensurations (cm)</div>
                    <div class="measure-grid">
                        <div class="field">{{ form_label(form.m_poitrine) }}{{ form_widget(form.m_poitrine) }}</div>
                        <div class="field">{{ form_label(form.m_taille) }}{{ form_widget(form.m_taille) }}</div>
                        <div class="field">{{ form_label(form.m_hanches) }}{{ form_widget(form.m_hanches) }}</div>
                        <div class="field">{{ form_label(form.m_hauteur) }}{{ form_widget(form.m_hauteur) }}</div>
                    </div>
                </div>
            {% endif %}

            <div class="qty-add">
                <div class="field">
                    <label>Qte</label>
                    {{ form_widget(form.quantity) }}
                </div>
                <button type="submit" class="btn btn-block" style="align-self:flex-end">Ajouter au panier</button>
            </div>
        {{ form_end(form) }}

        {% if product.isCustomizable and app.user %}
            <div style="margin-top:24px;padding:20px;border:1px dashed var(--line-strong);border-radius:12px">
                <div class="block-label" style="margin-top:0;display:flex;justify-content:space-between;align-items:center">
                    <span>Demander un devis sur mesure</span>
                    <label style="text-transform:none;letter-spacing:0;font-weight:400;cursor:pointer">
                        <input type="checkbox" id="devis-toggle"> Oui
                    </label>
                </div>
                <div id="devis-block" style="display:none">
                    <p class="muted" style="font-size:13px;margin:8px 0 12px">Décrivez la personnalisation souhaitée : nous vous proposerons un prix.</p>
                    <form method="post" action="{{ path('app_customization_request', {slug: product.slug}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('customization_request' ~ product.id) }}">
                        <div class="field" style="margin-bottom:12px">
                            <textarea class="input" name="description" rows="3" placeholder="Ex : cette création en coton écru, anse plus longue..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-outline btn-sm">Envoyer ma demande</button>
                    </form>
                </div>
            </div>
        {% endif %}

        <div class="accordion">
            <details open>
                <summary>Description <span>+</span></summary>
                <p>{{ product.description|nl2br }}</p>
            </details>
            <details>
                <summary>Livraison &amp; retours <span>+</span></summary>
                <p class="muted">Chaque piece est crochetee a la main : comptez 2 a 3 semaines de realisation pour les creations sur-mesure. Livraison suivie en France et a l'international.</p>
            </details>
            {% if product.tags|length %}
            <details>
                <summary>Details <span>+</span></summary>
                <p class="muted">Tags : {% for t in product.tags %}{{ t.name }}{{ not loop.last ? ', ' }}{% endfor %}</p>
            </details>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var form = document.querySelector('.pd-info form');
    if (!form) return;

    // Mensurations : visibles uniquement quand "Creation physique" est selectionne.
    var measures = document.getElementById('measure-block');
    var typeRadios = form.querySelectorAll('input[name$="[selectedType]"]');

    function syncMeasures() {
        if (!measures) return;
        var checked = form.querySelector('input[name$="[selectedType]"]:checked');
        measures.style.display = (checked && checked.value === 'physical') ? '' : 'none';
    }
    typeRadios.forEach(function (r) { r.addEventListener('change', syncMeasures); });
    syncMeasures();

    // Personnalisation : la zone de texte n'apparait que si l'interrupteur est active.
    // Devis sur mesure : le formulaire n'apparaît que si l'interrupteur est activé.
    var devisToggle = document.getElementById('devis-toggle');
    var devisBlock = document.getElementById('devis-block');
    if (devisToggle && devisBlock) {
        devisToggle.addEventListener('change', function () {
            devisBlock.style.display = devisToggle.checked ? '' : 'none';
        });
    }
})();
</script>
{% endblock %}
