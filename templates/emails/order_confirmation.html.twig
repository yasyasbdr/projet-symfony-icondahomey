<!doctype html>
<html lang="fr">
<head><meta charset="UTF-8"></head>
<body style="font-family:Arial,sans-serif;background:#F4EFE6;padding:30px;color:#1C1A16">
    <div style="max-width:560px;margin:auto;background:#fff;border-radius:14px;overflow:hidden;border:1px solid #E4DBCB">
        <div style="background:#1B1A15;color:#fff;padding:26px 30px">
            <div style="font-size:26px">Icon Dahomey</div>
        </div>
        <div style="padding:30px">
            <h1 style="font-size:22px;margin:0 0 10px">Merci pour votre commande, {{ order.customer.firstName }} !</h1>
            <p style="color:#57534A">Votre commande <strong>{{ order.reference }}</strong> a bien ete enregistree. Nous commencons la fabrication de vos creations.</p>

            <table style="width:100%;border-collapse:collapse;margin:20px 0">
                {% for item in order.items %}
                    <tr style="border-bottom:1px solid #E4DBCB">
                        <td style="padding:10px 0">{{ item.productName }} <span style="color:#8B8577">x{{ item.quantity }}</span></td>
                        <td style="padding:10px 0;text-align:right">{{ item.lineTotal }} &euro;</td>
                    </tr>
                {% endfor %}
                <tr><td style="padding:14px 0;font-weight:bold">Total</td>
                    <td style="padding:14px 0;text-align:right;font-weight:bold">{{ order.totalAmount }} &euro;</td></tr>
            </table>

            <p style="color:#57534A;font-size:14px">Vous pouvez suivre l'avancement de votre commande depuis votre espace client.</p>
        </div>
        <div style="background:#F4EFE6;padding:18px 30px;font-size:12px;color:#8B8577;text-align:center">
            Icon Dahomey — Crochet. Culture. Crafted to iconic.
        </div>
    </div>
</body>
</html>
